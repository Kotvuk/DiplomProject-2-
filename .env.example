# =============================================================================
# KotvukAI Environment Configuration
# =============================================================================

# Server Configuration
PORT=3001
NODE_ENV=development

# =============================================================================
# DATABASE - PostgreSQL (Neon.tech)
# =============================================================================
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# =============================================================================
# JWT Secrets (минимум 32 символа!)
# =============================================================================
JWT_SECRET=your_jwt_secret_minimum_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_secret_minimum_32_characters

# =============================================================================
# GROQ API KEYS - 15 ключей, разделённых на 3 группы
# =============================================================================

# Группа 1: Kimi K2 (ключи 1-5)
# Использование: глубокий анализ, backtesting, длинный контекст
# Модель: moonshotai/kimi-k2-instruct-0905
GROQ_KEY_KIMI_1=your_groq_api_key_1
GROQ_KEY_KIMI_2=your_groq_api_key_2
GROQ_KEY_KIMI_3=your_groq_api_key_3
GROQ_KEY_KIMI_4=your_groq_api_key_4
GROQ_KEY_KIMI_5=your_groq_api_key_5

# Группа 2: Llama 4 Maverick (ключи 6-10)
# Использование: reasoning, стратегии, самоанализ ботов
# Модель: meta-llama/llama-4-maverick-17b-128e-instruct
GROQ_KEY_LLAMA_1=your_groq_api_key_6
GROQ_KEY_LLAMA_2=your_groq_api_key_7
GROQ_KEY_LLAMA_3=your_groq_api_key_8
GROQ_KEY_LLAMA_4=your_groq_api_key_9
GROQ_KEY_LLAMA_5=your_groq_api_key_10

# Группа 3: Qwen 3 32B (ключи 11-15)
# Использование: быстрые сигналы, мульти-таймфрейм анализ, чат
# Модель: qwen/qwen3-32b
GROQ_KEY_QWEN_1=your_groq_api_key_11
GROQ_KEY_QWEN_2=your_groq_api_key_12
GROQ_KEY_QWEN_3=your_groq_api_key_13
GROQ_KEY_QWEN_4=your_groq_api_key_14
GROQ_KEY_QWEN_5=your_groq_api_key_15

# =============================================================================
# LEGACY KEY (для обратной совместимости)
# =============================================================================
GROQ_API_KEY=your_groq_legacy_key

# =============================================================================
# TELEGRAM BOT (опционально)
# =============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# =============================================================================
# SECURITY
# =============================================================================
# 2FA Settings
TWO_FA_ENABLED=true
TWO_FA_ISSUER=KotvukAI

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info

# Push Notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# KotvukAI — настройки окружения

PORT=3001
NODE_ENV=development

# PostgreSQL (Neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT (минимум 32 символа!)
JWT_SECRET=your_jwt_secret_minimum_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_secret_minimum_32_characters

# Groq API ключи — 15 штук, 3 группы по 5
# round-robin ротация, при 429 автоматом переключается на следующую группу

# Kimi K2 — глубокий анализ, backtesting
GROQ_KEY_KIMI_1=
GROQ_KEY_KIMI_2=
GROQ_KEY_KIMI_3=
GROQ_KEY_KIMI_4=
GROQ_KEY_KIMI_5=

# Llama 4 Maverick — reasoning, стратегии
GROQ_KEY_LLAMA_1=
GROQ_KEY_LLAMA_2=
GROQ_KEY_LLAMA_3=
GROQ_KEY_LLAMA_4=
GROQ_KEY_LLAMA_5=

# Qwen 3 32B — быстрые сигналы, чат
GROQ_KEY_QWEN_1=
GROQ_KEY_QWEN_2=
GROQ_KEY_QWEN_3=
GROQ_KEY_QWEN_4=
GROQ_KEY_QWEN_5=

# legacy fallback
GROQ_API_KEY=

# Telegram бот (опционально)
TELEGRAM_BOT_TOKEN=

# 2FA
TWO_FA_ENABLED=true
TWO_FA_ISSUER=KotvukAI

# Push (генерировать: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

LOG_LEVEL=info
